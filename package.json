{
  "name": "mitgliederverwaltung",
  "version": "1.0.0",
  "description": "Electron desktop wrapper für die Mitgliederverwaltung Senioren Lübars",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/server.js",
    "db:export": "node scripts/create-mysql-data-changelog.js",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "de.seniorenluebars.mitgliederverwaltung",
    "productName": "Mitgliederverwaltung",
    "directories": {
      "output": "dist"
    },
    "files": [
      "assets/**/*",
      "app.js",
      "index.html",
      "main.js",
      "preload.js",
      "styles.css",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "mysql2": "^3.11.5",
    "bootstrap": "^5.3.8",
    "ag-grid-community": "^35.3.0",
    "chart.js": "^4.5.1"
  }
}
